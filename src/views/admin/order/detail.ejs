>>>>>>> 68aa47a0bde606efc9723c910e286db432ddf0cc
                            </div>

                            <!-- Breadcrumb -->
                            <ol class="breadcrumb mb-4">
                                <li class="breadcrumb-item"><a href="/admin">Dashboard</a></li>
                                <li class="breadcrumb-item"><a href="/admin/order">Đơn hàng</a></li>
                                <li class="breadcrumb-item active">Chi tiết</li>
                            </ol>

                            <div class="row g-4 mb-4">
                                <!-- Thông tin đơn hàng -->
                                <div class="col-md-6">
                                    <div class="card shadow-sm">
                                        <div class="card-header bg-primary text-white fw-semibold">Thông tin đơn hàng
                                        </div>
                                        <div class="card-body">
                                            <p><strong>Mã đơn:</strong>
                                                <%= order.id %>
                                            </p>
                                            <p><strong>Ngày đặt:</strong>
                                                <%= formattedCreatedAtVN %>
                                            </p>
                                            <p><strong>Trạng thái:</strong>
                                                <% if(order.status==='PENDING' ){ %>
                                                    <span class="badge bg-warning text-dark">Chờ xử lý</span>
                                                    <% } else if(order.status==='COMPLETE' ){ %>
                                                        <span class="badge bg-success">Hoàn tất</span>
                                                        <% } else if(order.status==='CANCELED' ){ %>
                                                            <span class="badge bg-danger">Đã hủy</span>
                                                            <% if(order.cancelReason){ %>
                                                                <br><small class="text-muted">Lý do: <%=
                                                                        order.cancelReason %></small>
                                                                <% } %>
                                                                    <% } %>
                                            </p>
                                            <p><strong>Phương thức thanh toán:</strong>
                                                <%= order.paymentMethod %>
                                            </p>
                                            <p><strong>Trạng thái thanh toán:</strong>
                                                <%= order.paymentStatus %>
                                            </p>
                                            <p><strong>Tổng tiền:</strong>
                                                <%= new Intl.NumberFormat('vi-VN',{style:'currency',
                                                    currency:'VND'}).format(order.totalPrice) %>
                                            </p>
                                            <p><strong>Ghi chú khách:</strong>
                                                <%= order.receiverNote || "-" %>
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                <!-- Thông tin người nhận -->
                                <div class="col-md-6">
                                    <div class="card shadow-sm">
                                        <div class="card-header bg-primary text-white fw-semibold">Thông tin người nhận
                                        </div>
                                        <div class="card-body">
                                            <p><strong>Tên:</strong>
                                                <%= order.receiverName %>
                                            </p>
                                            <p><strong>SĐT:</strong>
                                                <%= order.receiverPhone %>
                                            </p>
                                            <p><strong>Địa chỉ:</strong>
                                                <%= order.receiverAddress %>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Chi tiết sản phẩm -->
                            <div class="card shadow-sm mb-4">
                                <div class="card-header bg-primary text-white fw-semibold">Chi tiết sản phẩm</div>
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Ảnh</th>
                                                <th>Sản phẩm</th>
                                                <th>Giá</th>
                                                <th>Số lượng</th>
                                                <th>Tổng tiền</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% orderDetails.forEach(orderDetail=> { %>
                                                <tr>
                                                    <td>
                                                        <img src="/images/product/<%= orderDetail.product.image %>"
                                                            class="img-fluid rounded" style="width:70px;height:70px;">
                                                    </td>
                                                    <td>
                                                        <a target="_blank"
                                                            href="/product/<%= orderDetail.product.id %>">
                                                            <%= orderDetail.product.name %>
                                                        </a>
                                                    </td>
                                                    <td>
                                                        <%= new Intl.NumberFormat('vi-VN',{style:'currency',
                                                            currency:'VND'}).format(orderDetail.price) %>
                                                    </td>
                                                    <td>
                                                        <%= orderDetail.quantity %>
                                                    </td>
                                                    <td>
                                                        <%= new Intl.NumberFormat('vi-VN',{style:'currency',
                                                            currency:'VND'}).format(orderDetail.price *
                                                            orderDetail.quantity) %>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <!-- Hành động admin -->
                            <% if(order.status==='PENDING' ){ %>
                                <div class="mb-4 d-flex gap-2">
                                    <form action="/admin/order/<%= order.id %>/confirm" method="post">
                                        <button type="submit" class="btn btn-success"><i class="fas fa-check"></i> Xác
                                            nhận đơn</button>
                                    </form>
                                    <button type="button" class="btn btn-danger" data-bs-toggle="modal"
                                        data-bs-target="#cancelModal">
                                        <i class="fas fa-times"></i> Hủy đơn
                                    </button>
                                </div>

