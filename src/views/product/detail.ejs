    <!-- nút xem thêm -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const desc = document.getElementById("desc-wrapper");
            const btn = document.getElementById("toggle-desc");

            btn.addEventListener("click", function () {
                desc.classList.toggle("desc-collapsed");

                if (desc.classList.contains("desc-collapsed")) {
                    btn.innerText = "Xem thêm";
                } else {
                    btn.innerText = "Thu gọn";
                }
            });
        });
        // Cài đặt thời gian kết thúc (ví dụ: 14 tiếng sau kể từ khi load trang)
        let endTime = new Date().getTime() + (14 * 60 * 60 * 1000);

        function updateCountdown() {
            let now = new Date().getTime();
            let distance = endTime - now;

            if (distance < 0) {
                document.getElementById("countdown").innerHTML = "Hết hạn";
                clearInterval(timer);
                return;
            }

            // Tính giờ, phút, giây
            let hours = Math.floor((distance / (1000 * 60 * 60)) % 24);
            let minutes = Math.floor((distance / (1000 * 60)) % 60);
            let seconds = Math.floor((distance / 1000) % 60);

            // Format 2 chữ số
            hours = hours.toString().padStart(2, '0');
            minutes = minutes.toString().padStart(2, '0');
            seconds = seconds.toString().padStart(2, '0');

            document.getElementById("countdown").innerHTML = `${hours}:${minutes}:${seconds}`;
        }

        // Cập nhật mỗi giây
        let timer = setInterval(updateCountdown, 1000);
        updateCountdown();


    </script>

