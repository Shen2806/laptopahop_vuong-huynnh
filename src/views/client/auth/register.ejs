<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Tạo tài khoản - LaptopShop</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet"
        crossorigin="anonymous">

    <!-- Font Awesome -->
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>

    <style>
        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            background: url("/images/logo/login.png") no-repeat center center fixed;
            background-size: cover;
            /* tự động scale full màn hình */
            background-attachment: fixed;
            /* giữ cố định khi scroll */
        }

        .register-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .register-card {
            width: 100%;
            max-width: 950px;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            background: #fff;
            display: flex;
        }

        .register-left {
            flex: 1;
            background: #f8f9fa;
            padding: 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .register-left h3 {
            font-size: 30px;
            font-weight: 600;
            margin-bottom: 20px;
        }

        .register-left ul {
            list-style: none;
            padding: 0;
        }

        .register-left ul li {
            margin-bottom: 14px;
            font-size: 15px;
            display: flex;
            align-items: center;
        }

        .register-left ul li i {
            margin-right: 8px;
            /* tạo khoảng cách giữa icon và chữ */
            font-size: 18px;
            /* icon nhìn cân hơn với chữ */
            vertical-align: middle;
            /* căn giữa icon với chữ */
        }

        /* Bên phải - Form */
        .register-right {
            flex: 1;
            padding: 60px 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .register-right h3 {
            text-align: center;
            margin-bottom: 24px;
            font-weight: 700;
        }

        .btn-primary {
            background-color: #0066ff;
            border: none;
        }

        .btn-primary:hover {
            background-color: #0052cc;
        }

        .logo-row {
            padding-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 78px;
            /* khoảng cách giữa ảnh */
        }
    </style>
</head>

<body>
    <div class="register-wrapper" style="margin-right: 20px; padding-bottom: 100px">
        <div class="register-card">

            <!-- Ưu đãi bên trái -->
            <div class="register-left">
                <div class="logo-row mb-4">
                    <img src="/images/logo/logosmall.png" alt="Logo nhỏ" style="height: 70px; width: 160px;">
                    <img src="/images/logo/logo.png" alt="Logo lớn" style="height: 70px; width: 160px;">
                </div>

                <div style="margin-bottom: 10px;">
                    <h4>Khách hàng thành viên <span class="text-primary" style="font-size: 30px;">SMEMBER </span></h4>
                </div>

                <ul>
                    <li><i class="fa-solid fa-gift text-primary"></i><span> Chiết khấu <b>5%</b> khi mua sản phẩm tại
                        LaptopShop</span></li>
                    <li><i class="fa-solid fa-truck-fast text-success"></i><span> Miễn phí giao hàng cho đơn hàng từ <b>300.000đ</b></span>
                    </li>
                    <li><i class="fa-solid fa-ticket text-danger"></i> <span>Tặng <b>voucher 500.000đ</b> cho khách hàng thành
                        viên </span></li>
                    <li><i class="fa-solid fa-graduation-cap text-warning"></i><span> Ưu đãi thêm <b>10%</b> cho
                        S-Student/S-Teacher</span></li>
                </ul>
            </div>

            <!-- Form bên phải -->
            <div class="register-right">
                <h3 style="color: red;">Tạo tài khoản</h3>
                <% errors.forEach(function(error) { %>
                    <div class="alert alert-danger mb-3">
                        <%= error %>
                    </div>
                    <% }) %>
                        <form method="POST" action="/register">
                            <div class="form-floating mb-3">
                                <input value="<%= oldData.fullName%>" class="form-control" id="fullName" type="text"
                                    placeholder="Your name..." name="fullName" />
                                <label for="fullName">Họ và tên</label>
                            </div>
                            <div class="form-floating mb-3">
                                <input value="<%= oldData.email%>" class="form-control" id="email" type="email"
                                    placeholder="name@example.com" name="email" />
                                <label for="email">Email</label>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <div class="form-floating mb-3 mb-md-0">
                                        <input value="<%= oldData.password%>" class="form-control" id="password"
                                            type="password" name="password" placeholder="Create a password" />
                                        <label for="password">Mật khẩu</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating mb-3 mb-md-0">
                                        <input value="<%= oldData.confirmPassword%>" class="form-control"
                                            id="confirmPassword" name="confirmPassword" type="password"
                                            placeholder="Confirm password" />
                                        <label for="confirmPassword">Xác nhận mật khẩu</label>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-4 mb-0">
                                <div class="d-grid">
                                    <button class="btn btn-primary btn-block w-100">Tạo tài khoản</button>
                                </div>
                            </div>
                        </form>
                        <div class="text-center py-3">
                            <div class="small">Bạn đã có tài khoản?<a href="/login"> Đăng Nhập</a></div>
                        </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"
        crossorigin="anonymous"></script>
</body>

</html>