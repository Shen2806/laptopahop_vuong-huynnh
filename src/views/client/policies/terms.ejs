<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8">
    <title>
        <%= typeof title !=='undefined' ? title : 'Điều khoản sử dụng ' %>
    </title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta name="description" content="Điều khoản sử dụng cho trang web mua sắm LaptopShop">

    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600&family=Raleway:wght@600;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Libraries -->
    <link href="/client/lib/lightbox/css/lightbox.min.css" rel="stylesheet">
    <link href="/client/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">

    <!-- Bootstrap & Template -->
    <link href="/client/css/bootstrap.min.css" rel="stylesheet">
    <link href="/client/css/style.css" rel="stylesheet">

    <style>
        .toc a {
            text-decoration: none;
        }

        .toc a:hover {
            text-decoration: underline;
        }

        .terms-section h3 {
            scroll-margin-top: 100px;
        }

        /* tránh bị che bởi navbar */
        .callout {
            background: #f8f9fa;
            border: 1px solid #eee;
            padding: 12px 16px;
            border-radius: 10px;
        }

        .terms-updated {
            font-size: 14px;
            color: #6c757d;
        }
    </style>
</head>

<body>

    <!-- HEADER (nếu bạn đang dùng layout chung, có thể bỏ toàn bộ block header/topbar dưới đây) -->
    <div class="container-fluid shadow" style="margin-top: 10px">
        <div class="container topbar bg-primary d-none d-lg-block">
            <div class="d-flex justify-content-between">
                <div class="top-info ps-2">
                    <% if (typeof user !=='undefined' && user) { %>
                        <small class="me-3"><i class="fas fa-map-marker-alt me-2 text-secondary"></i>
                            <a href="#" class="text-white">
                                <%= user?.address || '' %>
                            </a>
                        </small>
                        <small class="me-3"><i class="fas fa-envelope me-2 text-secondary"></i>
                            <a href="#" class="text-white">
                                <%= user?.username || '' %>
                            </a>
                        </small>
                        <% } %>
                </div>
                <div class="top-link pe-2">
                    <a href="/terms" class="text-white"><small class="text-white mx-2">Điều khoản sử dụng</small>/</a>
                    <a href="/support" class="text-white"><small class="text-white mx-2">Hỗ trợ</small></a>
                </div>
            </div>
        </div>

        <div class="container px-0">
            <nav class="navbar navbar-light bg-white navbar-expand-xl">
                <a href="/" class="navbar-brand">
                    <h1 class="text-primary display-6">
                        <%= typeof companyName !=='undefined' ? companyName : 'LaptopShop-VH' %>
                    </h1>
                </a>
                <button class="navbar-toggler py-2 px-3" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarCollapse">
                    <span class="fa fa-bars text-primary"></span>
                </button>

                <div class="collapse navbar-collapse bg-white" id="navbarCollapse">
                    <div class="navbar-nav mx-auto">
                        <a href="/" class="nav-item nav-link">Trang chủ</a>
                        <a href="/products" class="nav-item nav-link">Sản phẩm</a>
                        <a href="/terms" class="nav-item nav-link active">Điều khoản</a>
                    </div>

                    <div class="d-flex ms-auto">
                        <a href="/cart" class="position-relative me-4 my-auto">
                            <i class="fa fa-shopping-bag fa-2x"></i>
                            <span
                                class="position-absolute bg-secondary rounded-circle d-flex align-items-center justify-content-center text-dark px-1"
                                style="top: -5px; left: 15px; height: 20px; min-width: 20px;" id="sumCart">
                                <%= (user && user.sumCart) ? user.sumCart : 0 %>
                            </span>
                        </a>

                        <% if (typeof user !=='undefined' && user) { %>
                            <div class="dropdown my-auto">
                                <a href="#" class="dropdown" id="dropdownMenuLink" data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                    <i class="fas fa-user fa-2x"></i>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end p-4" aria-labelledby="dropdownMenuLink">
                                    <li class="d-flex align-items-center flex-column" style="min-width: 300px;">
                                        <img style="width: 150px; height: 150px; border-radius: 50%; overflow: hidden;"
                                            src="/images/<%= user.avatar %>" />
                                        <div class="text-center my-3">
                                            <%= user.fullName %>
                                        </div>
                                    </li>
                                    <li><a class="dropdown-item" href="/profile">Thông tin cá nhân</a></li>
                                    <li><a class="dropdown-item" href="/order-history">Lịch sử mua hàng</a></li>
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                    <li>
                                        <form method="post" action="/logout"><button class="dropdown-item">Đăng
                                                xuất</button></form>
                                    </li>
                                </ul>
                            </div>
                            <% } else { %>
                                <a href="/login" class="a-login"><i class="fas fa-user fa-2x"></i></a>
                                <% } %>
                    </div>
                </div>
            </nav>
        </div>
    </div>
    <!-- /HEADER -->

    <div class="py-1"></div>

    <!-- CONTENT -->
    <div class="container my-4">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page">Điều khoản sử dụng</li>
            </ol>
        </nav>

        <div class="row g-4">
            <div class="col-12 col-lg-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="mb-3">Mục lục</h5>
                        <ul class="list-unstyled toc">
                            <li><a href="#intro">1. Giới thiệu</a></li>
                            <li><a href="#defs">2. Định nghĩa</a></li>
                            <li><a href="#account">3. Tài khoản & bảo mật</a></li>
                            <li><a href="#order">4. Đặt hàng & xác nhận</a></li>
                            <li><a href="#price">5. Giá & thanh toán</a></li>
                            <li><a href="#ship">6. Giao hàng</a></li>
                            <li><a href="#return">7. Bảo hành & đổi trả</a></li>
                            <li><a href="#ip">8. Quyền sở hữu trí tuệ</a></li>
                            <li><a href="#prohibited">9. Hành vi bị cấm</a></li>
                            <li><a href="#liability">10. Trách nhiệm & miễn trừ</a></li>
                            <li><a href="#privacy">11. Quyền riêng tư</a></li>
                            <li><a href="#law">12. Luật áp dụng & tranh chấp</a></li>
                            <li><a href="#changes">13. Sửa đổi điều khoản</a></li>
                            <li><a href="#contact">14. Liên hệ</a></li>
                        </ul>
                        <div class="terms-updated mt-3">
                            Cập nhật lần cuối:
                            <%= typeof lastUpdated !=='undefined' ? lastUpdated : (new
                                Date()).toLocaleDateString('vi-VN') %>
                        </div>
                    </div>
                </div>

            </div>

            <div class="col-12 col-lg-9 terms-section">
                <div class="card">
                    <div class="card-body">
                        <h2 class="mb-3">Điều khoản sử dụng</h2>
                        <p>
                            Chào mừng bạn đến với
                            <strong>
                                <%= typeof companyName !=='undefined' ? companyName : 'LaptopShop' %>
                            </strong>.
                            Khi truy cập và mua sắm tại website này, bạn đồng ý tuân thủ các Điều khoản sử dụng dưới
                            đây.
                            Vui lòng đọc kỹ trước khi sử dụng dịch vụ.
                        </p>

                        <hr class="my-4">

                        <h3 id="intro" class="mt-4">1. Giới thiệu</h3>
                        <p>
                            Website do
                            <strong>
                                <%= typeof companyName !=='undefined' ? companyName : 'LaptopShop' %>
                            </strong>
                            vận hành nhằm cung cấp sản phẩm máy tính xách tay và phụ kiện chính hãng
                            cho khách hàng tại Việt Nam.
                        </p>

                        <h3 id="defs" class="mt-4">2. Định nghĩa</h3>
                        <ul>
                            <li><strong>“Website”</strong>: trang thương mại điện tử tại địa chỉ do
                                <%= typeof companyName !=='undefined' ? companyName : 'LaptopShop' %> quản lý.
                            </li>
                            <li><strong>“Khách hàng/Người dùng”</strong>: bất kỳ cá nhân/tổ chức truy cập hoặc mua hàng.
                            </li>
                            <li><strong>“Tài khoản”</strong>: thông tin đăng nhập do người dùng tạo để sử dụng dịch vụ.
                            </li>
                        </ul>

                        <h3 id="account" class="mt-4">3. Tài khoản & bảo mật</h3>
                        <ul>
                            <li>Thông tin đăng ký phải chính xác, đầy đủ và được cập nhật khi thay đổi.</li>
                            <li>Bạn chịu trách nhiệm bảo mật thông tin đăng nhập và mọi hoạt động phát sinh từ tài khoản
                                của mình.</li>
                            <li>Chúng tôi có thể tạm khóa hoặc chấm dứt tài khoản nếu phát hiện vi phạm điều khoản hoặc
                                có dấu hiệu gian lận.</li>
                        </ul>

                        <h3 id="order" class="mt-4">4. Đặt hàng & xác nhận</h3>
                        <ul>
                            <li>Đơn hàng chỉ được coi là <strong>xác nhận</strong> khi bạn nhận được thông báo xác nhận
                                từ hệ thống
                                hoặc từ bộ phận chăm sóc khách hàng.</li>
                            <li>Trong một số trường hợp (thiếu hàng, lỗi giá hiển thị, rủi ro giao dịch…), chúng tôi có
                                quyền từ chối
                                hoặc hủy đơn; mọi khoản thanh toán (nếu có) sẽ được hoàn lại theo chính sách hiện hành.
                            </li>
                        </ul>

                        <h3 id="price" class="mt-4">5. Giá & thanh toán</h3>
                        <ul>
                            <li>Giá hiển thị đã bao gồm/không bao gồm thuế, phí vận chuyển (sẽ thể hiện ở bước thanh
                                toán).</li>
                            <li>Chấp nhận các phương thức: tiền mặt khi nhận hàng (COD), chuyển khoản, cổng thanh toán
                                điện tử…</li>
                            <li>Giá có thể thay đổi tùy thời điểm; giá tại thời điểm xác nhận đơn hàng là giá áp dụng
                                cho đơn đó.</li>
                        </ul>

                        <h3 id="ship" class="mt-4">6. Giao hàng</h3>
                        <ul>
                            <li>Thời gian giao hàng dự kiến được thông báo khi đặt hàng; có thể thay đổi do điều kiện
                                khách quan.</li>
                            <li>Bạn cần cung cấp địa chỉ, số điện thoại chính xác để việc giao hàng diễn ra thuận lợi.
                            </li>
                            <li>Kiểm tra tình trạng niêm phong, ngoại quan trước khi ký nhận; phản hồi ngay nếu có vấn
                                đề.</li>
                        </ul>

                        <h3 id="return" class="mt-4">7. Bảo hành & đổi trả</h3>
                        <ul>
                            <li>Sản phẩm được áp dụng chính sách bảo hành của hãng hoặc của
                                <%= typeof companyName !=='undefined' ? companyName : 'LaptopShop' %> (nếu có công bố
                                    riêng).
                            </li>
                            <li>Điều kiện đổi trả: còn nguyên tem/mác, phụ kiện đi kèm, đầy đủ hóa đơn; không thuộc nhóm
                                bị từ chối theo quy định.</li>
                            <li>Thời hạn và quy trình cụ thể xem tại trang “Chính sách bảo hành & đổi trả”.</li>
                        </ul>

                        <h3 id="ip" class="mt-4">8. Quyền sở hữu trí tuệ</h3>
                        <p>
                            Toàn bộ nội dung, hình ảnh, nhãn hiệu, mã nguồn, bố cục trên website thuộc quyền sở hữu của
                            <%= typeof companyName !=='undefined' ? companyName : 'LaptopShop' %> hoặc đối tác và được
                                bảo hộ bởi pháp luật.
                                Nghiêm cấm sao chép, sử dụng trái phép dưới mọi hình thức nếu không có sự đồng ý bằng
                                văn bản.
                        </p>

                        <h3 id="prohibited" class="mt-4">9. Hành vi bị cấm</h3>
                        <ul>
                            <li>Sử dụng website cho mục đích gian lận, phát tán mã độc, tấn công hệ thống, thu thập dữ
                                liệu trái phép.</li>
                            <li>Giả mạo danh tính, lợi dụng lỗ hổng giá/khuyến mãi để trục lợi.</li>
                            <li>Đăng tải nội dung vi phạm pháp luật, thuần phong mỹ tục.</li>
                        </ul>

                        <h3 id="liability" class="mt-4">10. Trách nhiệm & miễn trừ</h3>
                        <ul>
                            <li>Chúng tôi nỗ lực đảm bảo thông tin chính xác, nhưng không đảm bảo tuyệt đối không có sai
                                sót ngoài ý muốn.</li>
                            <li>Không chịu trách nhiệm cho thiệt hại gián tiếp, lợi nhuận bị mất do việc sử dụng hoặc
                                không thể sử dụng website.</li>
                            <li>Trong mọi trường hợp, trách nhiệm tối đa của chúng tôi (nếu có) không vượt quá giá trị
                                đơn hàng liên quan.</li>
                        </ul>

                        <h3 id="privacy" class="mt-4">11. Quyền riêng tư</h3>
                        <p>
                            Việc thu thập và xử lý dữ liệu cá nhân được thực hiện theo “Chính sách quyền riêng tư”.
                            Khi sử dụng website, bạn đồng ý với các nội dung nêu trong chính sách này.
                        </p>

                        <h3 id="law" class="mt-4">12. Luật áp dụng & giải quyết tranh chấp</h3>
                        <p>
                            Điều khoản này được điều chỉnh bởi pháp luật Việt Nam. Bất kỳ tranh chấp nào phát sinh sẽ
                            ưu tiên giải quyết bằng thương lượng. Nếu không đạt được thỏa thuận, tranh chấp sẽ được đưa
                            ra
                            cơ quan có thẩm quyền tại Việt Nam để giải quyết.
                        </p>

                        <h3 id="changes" class="mt-4">13. Sửa đổi điều khoản</h3>
                        <p>
                            <%= typeof companyName !=='undefined' ? companyName : 'LaptopShop' %> có quyền cập nhật, sửa
                                đổi Điều khoản
                                bất kỳ lúc nào. Phiên bản cập nhật sẽ có hiệu lực kể từ ngày đăng tải hoặc ngày ghi rõ
                                trong thông báo.
                        </p>

                        <h3 id="contact" class="mt-4">14. Liên hệ</h3>
                        <p>Nếu có câu hỏi về Điều khoản, vui lòng liên hệ:</p>
                        <ul>
                            <li>Địa chỉ:
                                99 ABC, Thống Nhất, Gò Vấp, TP.HCM
                            </li>
                            <li>Email:
                                support@laptopshop.vn
                                </a>
                            </li>
                            <li>Điện thoại:
                                0999 887 744
                                </a>
                            </li>
                        </ul>

                        <div class="callout mt-4">
                            <small>
                                Bằng việc tiếp tục sử dụng website, bạn xác nhận đã đọc, hiểu và đồng ý với toàn bộ Điều
                                khoản sử dụng.
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div><!-- row -->
    </div><!-- /container -->

    <!-- FOOTER START -->
    <div class="container-fluid bg-dark text-white-50 footer pt-5 mt-5">
        <div class="container py-5">
            <div class="pb-4 mb-4" style="border-bottom: 1px solid rgba(226, 175, 24, 0.5) ;">
                <div class="row g-4">
                    <div class="col-lg-3">
                        <a href="#">
                            <h1 class="text-primary mb-0">LaptopShop-VH</h1>
                        </a>
                    </div>


                </div>
            </div>
            <div class="row g-5">
                <div class="col-lg-3 col-md-6">
                    <div class="footer-item">
                        <h4 class="text-light mb-3">Chất lượng là ưu tiên hàng đầu</h4>

                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="d-flex flex-column text-start footer-item">
                        <h4 class="text-light mb-3">Thông tin cửa hàng</h4>
                        <a class="btn-link" href="">Về chúng tôi</a>
                        <!-- <a class="btn-link" href="">Contact Us</a>
                    <a class="btn-link" href="">Privacy Policy</a>
                    <a class="btn-link" href="">Terms & Condition</a>
                    <a class="btn-link" href="">Return Policy</a>
                    <a class="btn-link" href="">FAQs & Help</a> -->
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="d-flex flex-column text-start footer-item">
                        <h4 class="text-light mb-3">Tài khoản</h4>
                        <a class="btn-link" href="">Tài khoản của tôi</a>
                        <!-- <a class="btn-link" href="">Shop details</a>
                    <a class="btn-link" href="">Shopping Cart</a>
                    <a class="btn-link" href="">Wishlist</a>
                    <a class="btn-link" href="">Order History</a>
                    <a class="btn-link" href="">International Orders</a> -->
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="footer-item">
                        <h4 class="text-light mb-3">Liên hệ</h4>
                        <p>Địa chỉ: 99 ABC, Thống nhất , Gò vấp</p>
                        <p>Email: vuonghuynhitk3@gmail.com</p>
                        <p>Điện thoại: 0999 887 744</p>
                        <p>Thời gian làm việc</p>
                        <p>Cả Tuần (8:00 - 20:00)</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid copyright bg-dark py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    <span class="text-light"><a href="#"><i
                                class="fas fa-copyright text-light me-2"></i>VuongHuynh-LaptopShop</a>, All right
                        reserved.</span>
                </div>
                <div class="col-md-6 my-auto text-center text-md-end text-white">
                    <!--/*** This template is free as long as you keep the below author’s credit link/attribution link/backlink. ***/-->
                    <!--/*** If you'd like to use the template without the below author’s credit link/attribution link/backlink, ***/-->
